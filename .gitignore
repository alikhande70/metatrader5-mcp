__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
build/
dist/

# secrets / local config - never commit credentials
.env
*.env.local

# runtime data (logs, approval files) - not source, machine-specific
logs/*.log
approvals/pending_*.json
approvals/approved_*.txt
approvals/approved2_*.txt
approvals/denied_*.txt

# bridge runtime artifacts - backups, rollback metadata, snapshots, drafts
backups/*
!backups/.gitkeep
drafts/*
!drafts/.gitkeep
workspace/*
!workspace/.gitkeep

.pytest_cache/
.mypy_cache/
.coverage
