# Copy this file to .env and fill in values. NEVER commit a real .env file.
# This project does not store secrets in code or in git - only local, untracked .env.

# --- MT5 terminal connection (all optional) ---
# If MT5_PATH is omitted, the already-running MetaTrader 5 terminal on this
# machine is used (MetaTrader5.initialize() with no path).
MT5_PATH=
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# --- Approval system ---
# console = interactive y/n prompt in the terminal running the MCP server
# file    = write approvals/pending_<id>.json and wait for approvals/approved_<id>.txt
MT5_MCP_APPROVAL_MODE=console

# --- Risk guard ---
# Order-planning tools (calculate_margin/calculate_profit/check_order/prepare_order_plan)
# are disabled by default, even on a demo account. Set to "true" to enable them on demo.
# Live/real accounts are ALWAYS blocked for these tools, regardless of this setting.
MT5_MCP_ENABLE_DEMO_TRADING=false

# --- Logging ---
MT5_MCP_LOG_DIR=logs
MT5_MCP_LOG_LEVEL=INFO

# --- Strategy Tester reports ---
# Directory that read_strategy_report / tester_import_csv are confined to. Only
# .html/.htm (reports) and .csv (imports) files inside this directory can be read;
# absolute paths and ../ traversal that escape it are rejected. If unset, the
# default is a 'reports/' directory under the runtime working directory.
MT5_MCP_REPORTS_DIR=

# --- MQL5 workspace (development tools) ---
# Root the MQL5 file/code tools are confined to. Point this at the terminal's
# MQL5 data folder (the one containing Experts/Indicators/Scripts/Include). Every
# file read/write is confined inside this root; absolute paths and ../ traversal
# are rejected. If unset, defaults to a 'workspace/' directory under cwd.
MT5_MCP_WORKSPACE_DIR=

# Where mutating file tools write backups + rollback metadata, and where workspace
# snapshots are stored. Defaults to 'backups/' under cwd.
MT5_MCP_BACKUPS_DIR=

# Where mql5_file_write_draft writes drafts (never the real source). Defaults to
# 'drafts/' under cwd.
MT5_MCP_DRAFTS_DIR=

# --- MetaEditor (compile tools; Windows only) ---
# Full path to metaeditor64.exe. Compile tools run only on Windows; off-Windows
# they return UNSUPPORTED_IN_THIS_ENVIRONMENT instead of doing anything.
METAEDITOR_PATH=
